{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/adquery-orchestrator-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "AllowedHosts": "*",
  "Claude": {
    "ApiKey": "",
    "BaseUrl": "https://api.portkey.ai",
    "AuthToken": "portkey",
    "Model": "@vertexai-global/anthropic.claude-sonnet-4@20250514"
  },
  "ActiveDirectory": {
    "RootPath": ""
  },
  "CustomMappings": {
    "EmployeeTypes": {
      "contractor": "EmployeeType -eq 'CWK'",
      "employee": "EmployeeType -eq 'EMP'",
      "vendor": "EmployeeType -eq 'VEN'"
    },
    "Licenses": {
      "F3": "ExtensionAttribute11 -eq 'F3'",
      "E3": "ExtensionAttribute11 -eq 'E3'",
      "E5": "ExtensionAttribute11 -eq 'E5'"
    },
    "ExtensionAttributes": {
      "ExtensionAttribute1": "CostCenter",
      "ExtensionAttribute2": "ManagerEmployeeID",
      "ExtensionAttribute11": "Office365License",
      "ExtensionAttribute12": "CustomField1"
    },
    "CommonQueries": {
      "active_users": "Enabled -eq $true",
      "disabled_users": "Enabled -eq $false",
      "never_logged_in": "LastLogonDate -notlike '*'",
      "locked_accounts": "LockedOut -eq $true"
    }
  },
  "OrganizationADSchema": {
    "NamingConventions": {
      "ActiveUsers": {
        "DisplayName": "Last, First | Last, First-MI | Last, First-MI# | Last, First-X",
        "CN": "Same as DisplayName typically",
        "SamAccountName": "FirstInitialLastName (max 8 chars, numbers for dupes: jsmith, jsmith1, jsmith99)",
        "UserPrincipalName": "First.Last@analog.com | First-MI.Last@analog.com | First-MI#.Last@analog.com | First-X.Last@analog.com",
        "Description": "Active user formats with duplicate handling"
      },
      "TerminatedUsers": {
        "DisplayName": "zzzzLast, zzzzFirst",
        "CN": "Likely same as DisplayName",
        "SamAccountName": "Original SamAccountName unchanged",
        "UserPrincipalName": "Original UPN unchanged or removed",
        "Description": "Terminated users get zzzz prefix on DisplayName"
      },
      "ServiceAccounts": {
        "DisplayName": "Varies - no standard",
        "CN": "Varies - no standard",
        "SamAccountName": "Varies - no standard",
        "ExtensionAttribute1": "Contains service account identifier",
        "Description": "Service accounts identified by ExtensionAttribute1"
      }
    },
    "SearchPatterns": {
      "PersonByFullName": "DisplayName -like '*{LastName}*{FirstName}*' -or DisplayName -like '*{FirstName}*{LastName}*' -or SamAccountName -like '{FirstInitial}{LastName}*' -or UserPrincipalName -like '{FirstName}*{LastName}*'",
      "PersonByLastName": "DisplayName -like '{LastName},*' -or SamAccountName -like '*{LastName}*' -or UserPrincipalName -like '*{LastName}@*'",
      "TerminatedPerson": "DisplayName -like 'zzzz{LastName}*' -or DisplayName -like 'zzzz*'",
      "DeletedObjects": "isDeleted -eq $true -and (DisplayName -like '*{SearchTerm}*' -or SamAccountName -like '*{SearchTerm}*')",
      "ServiceAccounts": "ExtensionAttribute1 -like '*service*' -or ExtensionAttribute1 -like '*svc*'"
    },
    "OrganizationalUnits": {
      "ActiveUsers": "OU=Users,OU=Corporate,DC=analog,DC=com",
      "TerminatedUsers": "OU=Terminated,OU=Archive,DC=analog,DC=com",
      "ServiceAccounts": "OU=ServiceAccounts,OU=Admin,DC=analog,DC=com",
      "Computers": "OU=Computers,OU=Corporate,DC=analog,DC=com"
    }
  },
  "QueryDefaults": {
    "MaxResultsDefault": 1000,
    "PreviewRowCount": 10,
    "AllowUnlimited": true
  },
  "Security": {
    "HmacSecretKey": "",
    "EnableHmacValidation": false,
    "MaxPlanComplexity": 10,
    "MaxExecutionTimeSeconds": 60,
    "AttributeFiles": {
      "User": "Configuration/user_allow_attr.txt",
      "Group": "Configuration/group_allow_attr.txt",
      "Computer": "Configuration/comp_allow_attr.txt",
      "OrganizationalUnit": "Configuration/ou_allow_attr.txt"
    }
  },
  "HealthChecks": {
    "CheckIntervalSeconds": 30
  }
}
