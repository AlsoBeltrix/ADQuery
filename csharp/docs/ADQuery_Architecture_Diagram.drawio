<mxfile host="app.diagrams.net">
  <diagram name="ADQuery Architecture" id="adquery-arch">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="ADQuery Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=28;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="300" height="40" as="geometry"/>
        </mxCell>

        <!-- Internal Network Zone -->
        <mxCell id="internal-zone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;strokeWidth=2;dashed=1;dashPattern=8 8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="700" height="700" as="geometry"/>
        </mxCell>
        <mxCell id="internal-label" value="Internal Network (On-Premises)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="50" y="85" width="250" height="25" as="geometry"/>
        </mxCell>

        <!-- External Zone -->
        <mxCell id="external-zone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF9800;strokeWidth=2;dashed=1;dashPattern=8 8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="780" y="80" width="280" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="external-label" value="External (Internet)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="790" y="85" width="150" height="25" as="geometry"/>
        </mxCell>

        <!-- User with PC -->
        <mxCell id="user-icon" value="" style="shape=actor;whiteSpace=wrap;html=1;fillColor=#1976D2;strokeColor=#0D47A1;" vertex="1" parent="1">
          <mxGeometry x="90" y="180" width="40" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="user-pc" value="" style="image;html=1;image=img/lib/icon_cloud/computer_win_client.svg" vertex="1" parent="1">
          <mxGeometry x="140" y="180" width="60" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="user-label" value="User&#xa;(Browser)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="85" y="245" width="120" height="30" as="geometry"/>
        </mxCell>

        <!-- Web Server -->
        <mxCell id="webserver" value="" style="image;html=1;image=img/lib/icon_cloud/server_app.svg" vertex="1" parent="1">
          <mxGeometry x="320" y="170" width="80" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="webserver-label" value="ADQuery&#xa;Web Server&#xa;(IIS / ASP.NET Core)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="255" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- Active Directory -->
        <mxCell id="ad-server" value="" style="image;html=1;image=img/lib/icon_cloud/server.svg" vertex="1" parent="1">
          <mxGeometry x="320" y="450" width="80" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="ad-icon" value="" style="image;html=1;image=img/lib/mscae/Active_Directory.svg" vertex="1" parent="1">
          <mxGeometry x="280" y="480" width="50" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="ad-label" value="Active Directory&#xa;(Domain Controllers)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="535" width="150" height="35" as="geometry"/>
        </mxCell>

        <!-- File Share -->
        <mxCell id="fileshare" value="" style="image;html=1;image=img/lib/icon_cloud/storage.svg" vertex="1" parent="1">
          <mxGeometry x="550" y="450" width="80" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="fileshare-label" value="File Share&#xa;(Results &amp; Logs)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="535" width="120" height="35" as="geometry"/>
        </mxCell>

        <!-- LLM API Cloud -->
        <mxCell id="llm-cloud" value="" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FF9800;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="830" y="150" width="180" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="llm-label" value="LLM API&#xa;(Portkey Gateway)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="865" y="185" width="110" height="50" as="geometry"/>
        </mxCell>

        <!-- Validation Box -->
        <mxCell id="validation" value="Plan Validation&#xa;&amp; Security Checks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;strokeWidth=2;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="185" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Arrows with labels -->

        <!-- User to Web Server -->
        <mxCell id="arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1976D2;endArrow=classic;endFill=1;" edge="1" parent="1" source="user-pc" target="webserver">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow1-label" value="HTTPS&#xa;(Win Auth)" style="text;html=1;strokeColor=none;fillColor=#E3F2FD;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#1976D2;" vertex="1" parent="1">
          <mxGeometry x="220" y="175" width="70" height="35" as="geometry"/>
        </mxCell>

        <!-- Web Server to LLM -->
        <mxCell id="arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#FF9800;endArrow=classic;endFill=1;dashed=1;" edge="1" parent="1" source="validation" target="llm-cloud">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow2-label" value="Query text +&#xa;schema context&#xa;(NO user data)" style="text;html=1;strokeColor=none;fillColor=#FFF3E0;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#E65100;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="120" width="90" height="50" as="geometry"/>
        </mxCell>

        <!-- LLM to Web Server (response) -->
        <mxCell id="arrow3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#FF9800;endArrow=classic;endFill=1;dashed=1;" edge="1" parent="1" source="llm-cloud" target="validation">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="770" y="270"/>
              <mxPoint x="770" y="270"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow3-label" value="JSON plan&#xa;(declarative,&#xa;not code)" style="text;html=1;strokeColor=none;fillColor=#FFF3E0;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#E65100;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="255" width="80" height="50" as="geometry"/>
        </mxCell>

        <!-- Web Server to AD -->
        <mxCell id="arrow4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4CAF50;endArrow=classic;endFill=1;startArrow=classic;startFill=1;" edge="1" parent="1" source="webserver" target="ad-server">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow4-label" value="LDAP&#xa;queries" style="text;html=1;strokeColor=none;fillColor=#E8F5E9;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="370" y="350" width="60" height="35" as="geometry"/>
        </mxCell>

        <!-- Web Server to File Share -->
        <mxCell id="arrow5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4CAF50;endArrow=classic;endFill=1;" edge="1" parent="1" source="webserver" target="fileshare">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="590" y="210"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow5-label" value="Results&#xa;&amp; audit logs" style="text;html=1;strokeColor=none;fillColor=#E8F5E9;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="530" y="340" width="70" height="35" as="geometry"/>
        </mxCell>

        <!-- Web Server to Validation -->
        <mxCell id="arrow6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1976D2;endArrow=classic;endFill=1;" edge="1" parent="1" source="webserver" target="validation">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#9E9E9E;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="620" width="300" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="legend-title" value="Data Flow Legend" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="625" width="120" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="leg-int" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#4CAF50;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="80" y="665" as="sourcePoint"/>
            <mxPoint x="140" y="665" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="leg-int-label" value="Internal traffic (all data stays here)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="150" y="655" width="200" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="leg-ext" value="" style="endArrow=classic;html=1;strokeWidth=3;strokeColor=#FF9800;dashed=1;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="80" y="700" as="sourcePoint"/>
            <mxPoint x="140" y="700" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="leg-ext-label" value="External traffic (query text only, NO data)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="150" y="690" width="200" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="leg-sec" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="725" width="60" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg-sec-label" value="Security validation gate" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="150" y="720" width="200" height="20" as="geometry"/>
        </mxCell>

        <!-- Key security callout -->
        <mxCell id="security-callout" value="✓ All user data remains on-premises&#xa;✓ Only query text sent externally&#xa;✓ LLM returns JSON plans, not code&#xa;✓ All plans validated before execution" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;size=30;position=0.5;base=20;fillColor=#E3F2FD;strokeColor=#1976D2;align=left;spacingLeft=10;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="810" y="470" width="230" height="100" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>